<Window x:Class="KeystrokeApp.Views.SuggestionPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        Background="Transparent"
        Opacity="0"
        SizeToContent="WidthAndHeight"
        MaxWidth="600"
        ResizeMode="NoResize">
    
    <Border x:Name="SuggestionBorder"
            Background="#CC161B22"
            CornerRadius="10"
            Padding="14,10"
            Margin="4"
            BorderBrush="#30FFFFFF"
            BorderThickness="1"
            Cursor="SizeAll"
            MouseLeftButtonDown="Border_MouseLeftButtonDown"
            MouseMove="Border_MouseMove"
            MouseLeftButtonUp="Border_MouseLeftButtonUp">

        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="ScaleTransform" ScaleX="0.95" ScaleY="0.95"/>
                <TranslateTransform x:Name="SlideTransform" Y="8"/>
            </TransformGroup>
        </Border.RenderTransform>
        
        <Border.Effect>
            <DropShadowEffect Color="Black" 
                              Opacity="0.5" 
                              BlurRadius="24" 
                              ShadowDepth="4"/>
        </Border.Effect>
        
        <StackPanel>
            <StackPanel x:Name="LoadingIndicator" 
                        Orientation="Horizontal" 
                        Visibility="Collapsed"
                        Margin="0,0,0,4">
                <TextBlock Text="Thinking" 
                           FontFamily="Segoe UI" FontSize="12"
                           Foreground="#8B949E"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="LoadingDots" 
                           FontFamily="Segoe UI" FontSize="12"
                           Foreground="#8B949E"
                           VerticalAlignment="Center"/>
            </StackPanel>
            
            <TextBlock x:Name="CompletionText"
                       FontFamily="Segoe UI" FontSize="14"
                       Foreground="#E0E0F0" FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       MaxWidth="560"/>

            <WrapPanel x:Name="CompletionWordsPanel" 
                       MaxWidth="560"
                       Visibility="Collapsed"/>

            <DockPanel Margin="0,6,0,0">
                <TextBlock x:Name="CounterText"
                           DockPanel.Dock="Right"
                           FontFamily="Segoe UI" FontSize="10"
                           Foreground="#7A7AAA" Margin="8,0,0,0"
                           Visibility="Collapsed"/>
                <TextBlock x:Name="HintText"
                           FontFamily="Segoe UI" FontSize="10"
                           Foreground="#5A5A7A"
                           Text="Tab accept · Ctrl+&#x2192; word · Esc dismiss"/>
            </DockPanel>
        </StackPanel>
    </Border>
</Window>
