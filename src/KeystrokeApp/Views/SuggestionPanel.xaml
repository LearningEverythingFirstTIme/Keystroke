<Window x:Class="KeystrokeApp.Views.SuggestionPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        Background="Transparent"
        Opacity="0"
        SizeToContent="WidthAndHeight"
        MaxWidth="620"
        ResizeMode="NoResize">

    <Border x:Name="SuggestionBorder"
            Background="#D8101825"
            CornerRadius="{StaticResource RadiusCard}"
            Padding="16,12"
            Margin="6"
            BorderBrush="#4A5B7390"
            BorderThickness="1"
            Cursor="SizeAll"
            MouseLeftButtonDown="Border_MouseLeftButtonDown"
            MouseEnter="Border_MouseEnter"
            MouseLeave="Border_MouseLeave">

        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="ScaleTransform" ScaleX="0.92" ScaleY="0.92"/>
                <TranslateTransform x:Name="SlideTransform" X="8" Y="18"/>
            </TransformGroup>
        </Border.RenderTransform>

        <Border.Effect>
            <DropShadowEffect x:Name="PanelGlow"
                              Color="#5050E8"
                              Opacity="0.18"
                              BlurRadius="22"
                              ShadowDepth="0"/>
        </Border.Effect>

        <StackPanel>
            <StackPanel x:Name="LoadingIndicator"
                        Orientation="Horizontal"
                        Visibility="Collapsed"
                        Margin="0,0,0,6">
                <TextBlock Text="Thinking"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           Foreground="{StaticResource TextMuted}"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="LoadingDots"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           Foreground="{StaticResource TextMuted}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock x:Name="CompletionText"
                       FontFamily="Cascadia Code, Consolas"
                       FontSize="14"
                       Foreground="{StaticResource TextPrimary}"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       MaxWidth="580"/>

            <WrapPanel x:Name="CompletionWordsPanel"
                       MaxWidth="580"
                       Visibility="Collapsed"/>

            <DockPanel Margin="0,8,0,0">
                <TextBlock x:Name="CounterText"
                           DockPanel.Dock="Right"
                           FontFamily="Segoe UI"
                           FontSize="10"
                           Foreground="#98AAC6"
                           Margin="10,0,0,0"
                           Visibility="Collapsed"/>
                <TextBlock x:Name="HintText"
                           FontFamily="Segoe UI"
                           FontSize="10"
                           Foreground="{StaticResource TextMuted}"
                           Text="Tab accept · Ctrl+&#x2192; word · Esc dismiss"/>
            </DockPanel>
        </StackPanel>
    </Border>
</Window>
