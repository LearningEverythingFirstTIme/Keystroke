<Window x:Class="KeystrokeApp.Views.SuggestionPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        IsHitTestVisible="False"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        MaxWidth="600"
        ResizeMode="NoResize">
    
    <Border x:Name="SuggestionBorder"
            Background="#E81E1E2E"
            CornerRadius="8"
            Padding="14,10"
            Margin="4"
            BorderBrush="#3A3A5A"
            BorderThickness="1">
        
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.5" BlurRadius="16" ShadowDepth="3"/>
        </Border.Effect>
        
        <StackPanel>
            <!-- The suggestion (completion from Gemini) -->
            <TextBlock x:Name="CompletionText"
                       FontFamily="Segoe UI" FontSize="14"
                       Foreground="#E0E0F0" FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       MaxWidth="560"/>

            <!-- Hint line with suggestion counter -->
            <DockPanel Margin="0,6,0,0">
                <TextBlock x:Name="CounterText"
                           DockPanel.Dock="Right"
                           FontFamily="Segoe UI" FontSize="10"
                           Foreground="#7A7AAA" Margin="8,0,0,0"
                           Visibility="Collapsed"/>
                <TextBlock x:Name="HintText"
                           FontFamily="Segoe UI" FontSize="10"
                           Foreground="#5A5A7A"
                           Text="Tab to accept · Esc to dismiss"/>
            </DockPanel>
        </StackPanel>
    </Border>
</Window>
