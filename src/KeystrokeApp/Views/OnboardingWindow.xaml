<Window x:Class="KeystrokeApp.Views.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to Keystroke"
        Width="760"
        Height="680"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0B1220">

    <Window.Resources>
        <SolidColorBrush x:Key="BgCard" Color="#111C2E"/>
        <SolidColorBrush x:Key="BgSoft" Color="#172338"/>
        <SolidColorBrush x:Key="BgInput" Color="#17263B"/>
        <SolidColorBrush x:Key="Accent" Color="#5EA6FF"/>
        <SolidColorBrush x:Key="Success" Color="#34C38F"/>
        <SolidColorBrush x:Key="Warning" Color="#F3A74F"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#CBD5E1"/>
        <SolidColorBrush x:Key="TextMuted" Color="#8CA0BB"/>
        <SolidColorBrush x:Key="Border" Color="#22324A"/>

        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="Button" x:Key="SecondaryButton">
            <Setter Property="Background" Value="{StaticResource BgSoft}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Welcome to Keystroke"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}"/>
            <TextBlock x:Name="SubtitleText"
                       Text="A quick setup will get you to live completions fast."
                       FontSize="13"
                       Margin="0,6,0,0"
                       Foreground="{StaticResource TextMuted}"/>

            <UniformGrid Columns="4" Margin="0,18,0,0">
                <Border x:Name="StepIndicator1" Style="{StaticResource CardStyle}" Margin="0,0,10,0" Padding="12">
                    <TextBlock Text="1. Welcome" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                </Border>
                <Border x:Name="StepIndicator2" Style="{StaticResource CardStyle}" Margin="0,0,10,0" Padding="12">
                    <TextBlock Text="2. Privacy" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                </Border>
                <Border x:Name="StepIndicator3" Style="{StaticResource CardStyle}" Margin="0,0,10,0" Padding="12">
                    <TextBlock Text="3. Gemini key" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                </Border>
                <Border x:Name="StepIndicator4" Style="{StaticResource CardStyle}" Padding="12">
                    <TextBlock Text="4. Ready" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                </Border>
            </UniformGrid>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,20,0,20">
            <Border x:Name="WelcomeStep" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Recommended setup"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="For most people, the best Keystroke experience starts with Gemini and Gemini 3.1 Flash-Lite Preview."
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="14"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="This is the setup we have tested the most, and it gives a strong balance of speed, accuracy, and cost for day-to-day autocomplete."
                               Foreground="{StaticResource TextMuted}"
                               FontSize="13"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"/>

                    <UniformGrid Columns="3" Margin="0,22,0,0">
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="Provider" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                                <TextBlock Text="Gemini" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                <TextBlock Text="Recommended default for most users." Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="Model" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                                <TextBlock Text="Gemini 3.1 Flash-Lite Preview" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                <TextBlock Text="Low latency, reliable quality, and low cost." Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Goal" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                                <TextBlock Text="See completions fast" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                <TextBlock Text="This setup gets you typing with minimal friction." Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Border x:Name="PrivacyStep" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Privacy and advanced features"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Keystroke needs your consent before it can watch typing, gather optional context, and send prediction requests."
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="14"
                                       Margin="0,10,0,0"
                                       TextWrapping="Wrap"/>

                            <Border Style="{StaticResource CardStyle}" Margin="0,20,0,0" Background="#3B2A20" BorderBrush="#6A4C3B">
                                <StackPanel>
                                    <TextBlock Text="What Keystroke captures locally" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold"/>
                                    <TextBlock Text="Keystroke watches typing and keeps the active text in memory long enough to generate, accept, and dismiss suggestions." Foreground="{StaticResource TextSecondary}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0" Background="#182E2B" BorderBrush="#245D50">
                                <StackPanel>
                                    <TextBlock Text="Recommended default features" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold"/>
                                    <TextBlock Text="OCR: on" Foreground="{StaticResource TextSecondary}" Margin="0,8,0,0"/>
                                    <TextBlock Text="Visible screen text helps keep completions grounded in the document, chat, or code you are looking at." Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"/>
                                    <TextBlock Text="Rolling context: on" Foreground="{StaticResource TextSecondary}" Margin="0,12,0,0"/>
                                    <TextBlock Text="Recent text helps Keystroke stay coherent across a sentence or thought." Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"/>
                                    <TextBlock Text="Learning: off" Foreground="{StaticResource TextSecondary}" Margin="0,12,0,0"/>
                                    <TextBlock Text="Keystroke will not store accepted suggestions for adaptation until you opt in later." Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="You can pause Keystroke from the tray, inspect the current data flow in Settings, block specific apps, or turn OCR and learning off at any time."
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="13"
                                       Margin="0,18,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>

                    <CheckBox x:Name="ConsentCheck"
                              Grid.Row="1"
                              Margin="0,18,0,0"
                              Foreground="{StaticResource TextPrimary}"
                              FontSize="13"
                              Checked="ConsentCheck_Changed"
                              Unchecked="ConsentCheck_Changed">
                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextPrimary}">
                            I understand how Keystroke monitors input, what optional context can be sent, and how to pause or limit it.
                        </TextBlock>
                    </CheckBox>
                </Grid>
            </Border>

            <Border x:Name="ApiKeyStep" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="Connect Gemini"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="Get a Gemini API key, paste it here, and verify it before Keystroke starts."
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="14"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"/>

                    <Border Style="{StaticResource CardStyle}" Margin="0,18,0,0" Background="{StaticResource BgSoft}">
                        <StackPanel>
                            <TextBlock Text="1. Open Google AI Studio" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold"/>
                            <TextBlock Text="2. Create or copy a Gemini API key" Foreground="{StaticResource TextSecondary}" Margin="0,8,0,0"/>
                            <TextBlock Text="3. Paste it below and click Verify key" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                            <WrapPanel Margin="0,14,0,0">
                                <Button Content="Open Google AI Studio" Style="{StaticResource PrimaryButton}" Click="OpenAiStudio_Click"/>
                                <Button Content="Open Settings instead" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0" Click="OpenSettingsInstead_Click"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Gemini API key" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,20,0,6"/>
                    <TextBox x:Name="GeminiApiKeyBox" TextChanged="GeminiApiKeyBox_Changed"/>

                    <WrapPanel Margin="0,16,0,0">
                        <Button x:Name="VerifyButton" Content="Verify key" Style="{StaticResource PrimaryButton}" Click="VerifyKey_Click"/>
                        <TextBlock x:Name="VerificationStatusText" Text="Paste a key to verify it." Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="14,0,0,0" TextWrapping="Wrap"/>
                    </WrapPanel>

                    <Border Style="{StaticResource CardStyle}" Margin="0,18,0,0" Background="#203047">
                        <StackPanel>
                            <TextBlock Text="Recommended first-run settings" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold"/>
                            <TextBlock Text="Provider: Gemini" Foreground="{StaticResource TextSecondary}" Margin="0,8,0,0"/>
                            <TextBlock Text="Model: Gemini 3.1 Flash-Lite Preview" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                            <TextBlock Text="OCR: on | Rolling context: on | Learning: off" Foreground="{StaticResource TextMuted}" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border x:Name="ReadyStep" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="Ready to start"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock x:Name="ReadySummaryText"
                               Text="Keystroke is ready to start with Gemini."
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="14"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"/>

                    <UniformGrid Columns="2" Margin="0,20,0,0">
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="What will be active" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold"/>
                                <TextBlock x:Name="ReadyActiveText" Text="Gemini completions with OCR and rolling context enabled." Foreground="{StaticResource TextSecondary}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="What you can change later" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold"/>
                                <TextBlock Text="You can switch providers, disable OCR, enable learning, or tighten app controls anytime in Settings." Foreground="{StaticResource TextSecondary}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Border x:Name="PausedSummaryCard" Style="{StaticResource CardStyle}" Margin="0,18,0,0" Background="#3B2A20" BorderBrush="#6A4C3B" Visibility="Collapsed">
                        <TextBlock Text="If you finish later, Keystroke will launch paused and wait for you to add a valid Gemini key before predictions start."
                                   Foreground="{StaticResource TextSecondary}"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="ExitButton" Grid.Column="0" Content="Decline &amp; Exit" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left" Click="ExitButton_Click"/>
            <Button x:Name="BackButton" Grid.Column="1" Content="Back" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0" Click="BackButton_Click"/>
            <Button x:Name="LaterButton" Grid.Column="2" Content="Finish later (start paused)" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0" Visibility="Collapsed" Click="LaterButton_Click"/>
            <Button x:Name="NextButton" Grid.Column="3" Content="Next" Style="{StaticResource PrimaryButton}" Click="NextButton_Click"/>
        </Grid>
    </Grid>
</Window>
