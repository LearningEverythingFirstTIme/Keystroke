<Window x:Class="KeystrokeApp.Views.ConsentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Keystroke — Privacy &amp; Consent"
        Width="560" Height="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1C2128">

    <Grid Margin="32,24,32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Welcome to Keystroke"
                       FontSize="22" FontWeight="Bold"
                       Foreground="#F0F6FC"/>
            <TextBlock Text="Please review exactly what Keystroke captures, stores, and sends before continuing."
                       FontSize="13" Foreground="#8B949E" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Scrollable consent text -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
            <TextBlock TextWrapping="Wrap" Foreground="#C9D1D9" FontSize="13" LineHeight="20">
                <Bold>What Keystroke captures locally</Bold><LineBreak/>
                Keystroke watches keyboard input so it can show autocomplete suggestions
                in the app you are currently using. It keeps the active typed text in
                memory long enough to build a prediction request and to manage accepts,
                dismissals, and word-by-word continuation.<LineBreak/>
                <LineBreak/>
                <Bold>What may be sent to your chosen model</Bold><LineBreak/>
                When predictions are enabled, Keystroke may send your current typed
                prefix, a privacy-safe app label, optional OCR text, optional recent
                accepted text, and optional learning hints to your selected provider.
                Raw window titles stay local. High-risk active input is blocked instead
                of being sent.<LineBreak/>
                <LineBreak/>
                <Bold>Optional context sources</Bold><LineBreak/>
                OCR screen reading and rolling context are both optional. If enabled,
                they help Keystroke stay grounded in the document, conversation, or
                code you are looking at. You can turn either feature off in Settings
                at any time.<LineBreak/>
                <LineBreak/>
                <Bold>What stays on your machine</Bold><LineBreak/>
                API keys are encrypted on disk with Windows DPAPI. If you enable
                Learning, accepted and dismissed suggestions are stored locally so the
                app can adapt to your writing style. Keystroke does not run telemetry
                or upload that local history anywhere on its own.<LineBreak/>
                <LineBreak/>
                <Bold>How text gets inserted</Bold><LineBreak/>
                When you accept a suggestion, Keystroke pastes the accepted text into
                the active app and then attempts to restore your clipboard. If the
                clipboard changes before restoration, Keystroke leaves it alone instead
                of overwriting newer clipboard contents.<LineBreak/>
                <LineBreak/>
                <Bold>Your controls</Bold><LineBreak/>
                You can pause Keystroke from the tray icon or with Ctrl+Shift+K, block
                specific apps, disable OCR, disable learning, inspect the current data
                flow in Settings, or reset local learning data at any time.
            </TextBlock>
        </ScrollViewer>

        <!-- Checkbox -->
        <CheckBox x:Name="AgreeCheck" Grid.Row="2" Margin="0,0,0,16"
                  Foreground="#C9D1D9" FontSize="13"
                  Checked="AgreeCheck_Changed" Unchecked="AgreeCheck_Changed">
            <TextBlock TextWrapping="Wrap" Foreground="#C9D1D9">
                I understand how Keystroke monitors input, what optional context can be sent, and how to pause or limit it.
            </TextBlock>
        </CheckBox>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="DeclineBtn" Content="Decline &amp; Exit"
                    Width="120" Height="34" Margin="0,0,12,0"
                    Click="Decline_Click"
                    Background="#30363D" Foreground="#C9D1D9"
                    BorderBrush="#484F58" BorderThickness="1"
                    Cursor="Hand"/>
            <Button x:Name="AcceptBtn" Content="Accept &amp; Continue"
                    Width="150" Height="34"
                    IsEnabled="False"
                    Click="Accept_Click"
                    Background="#238636" Foreground="#FFFFFF"
                    BorderBrush="#2EA043" BorderThickness="1"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
