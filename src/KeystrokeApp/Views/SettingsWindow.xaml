<Window x:Class="KeystrokeApp.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Keystroke Settings"
        Height="680" Width="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#0D1117">

    <Window.Resources>
        <!-- Override System Colors for ComboBox -->
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="White"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#1A1A2E"/>
        
        <!-- Colors -->
        <SolidColorBrush x:Key="BgDark" Color="#0D1117"/>
        <SolidColorBrush x:Key="BgCard" Color="#161B22"/>
        <SolidColorBrush x:Key="BgInput" Color="#21262D"/>
        <SolidColorBrush x:Key="BgHover" Color="#30363D"/>
        <SolidColorBrush x:Key="Accent" Color="#2F81F7"/>
        <SolidColorBrush x:Key="AccentHover" Color="#58A6FF"/>
        <SolidColorBrush x:Key="Success" Color="#238636"/>
        <SolidColorBrush x:Key="Warning" Color="#F0883E"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#F0F6FC"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8B949E"/>
        <SolidColorBrush x:Key="TextMuted" Color="#6E7681"/>
        <SolidColorBrush x:Key="Border" Color="#30363D"/>
        <SolidColorBrush x:Key="BorderLight" Color="#484F58"/>

        <!-- Styles -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <DockPanel>
                            <Border Name="Border" Background="Transparent" CornerRadius="6,6,0,0" Padding="{TemplateBinding Padding}" DockPanel.Dock="Top">
                                <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Name="Underline" Background="Transparent" Height="2" DockPanel.Dock="Bottom"/>
                        </DockPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource BgCard}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="Underline" Property="Background" Value="{StaticResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource BgHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="MainGrid" SnapsToDevicePixels="True">
                            <ToggleButton x:Name="DropDownToggle"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="32"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Selected item text -->
                                                <TextBlock x:Name="ContentText"
                                                           Text="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           FontSize="13"
                                                           VerticalAlignment="Center"
                                                           Margin="10,0,0,0"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <!-- Dropdown arrow -->
                                                <Path Grid.Column="1"
                                                      x:Name="Arrow"
                                                      Fill="{StaticResource TextSecondary}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource BorderLight}"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            
                            <!-- Popup for dropdown items -->
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade"
                                   StaysOpen="False">
                                <Border x:Name="DropDownBorder"
                                        Background="White"
                                        BorderBrush="{StaticResource BorderLight}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        MinWidth="{Binding ActualWidth, ElementName=MainGrid}"
                                        MaxHeight="350">
                                    <ScrollViewer x:Name="DropDownScrollViewer"
                                                  Margin="4"
                                                  Focusable="False">
                                        <ItemsPresenter x:Name="ItemsPresenter"
                                                        KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1A1A2E"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E8F0FE"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#D2E3FC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
            <Setter Property="Background" Value="{StaticResource Border}"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BgHover}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Border}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PresetButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <StackPanel>
                                <ContentPresenter HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource BgHover}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SwatchButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <Grid Margin="20,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="⚡ Keystroke" FontSize="20" FontWeight="Bold" 
                               Foreground="{StaticResource TextPrimary}" FontFamily="Segoe UI"/>
                    <TextBlock Text="Configure your AI autocomplete experience" 
                               Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="PresetMinimalBtn" Content="Minimal" Style="{StaticResource PresetButton}" 
                            Margin="0,0,8,0" Click="PresetMinimal_Click"/>
                    <Button x:Name="PresetBalancedBtn" Content="Balanced" Style="{StaticResource PresetButton}" 
                            Margin="0,0,8,0" Click="PresetBalanced_Click"/>
                    <Button x:Name="PresetMaxBtn" Content="Maximum" Style="{StaticResource PresetButton}" 
                            Click="PresetMaximum_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tabbed Content -->
        <TabControl Grid.Row="1" Margin="16,12,16,0">
            
            <!-- GENERAL TAB -->
            <TabItem Header="🧠 General">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,8,8,16">
                        
                        <!-- Engine Section -->
                        <Border Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Prediction Engine" FontSize="14" FontWeight="SemiBold" 
                                           Foreground="{StaticResource TextPrimary}" Margin="0,0,0,4"/>
                                <TextBlock Text="Choose which AI model powers your suggestions" 
                                           Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,12"/>
                                
                                <ComboBox x:Name="EngineCombo" Margin="0,0,0,12" SelectionChanged="EngineCombo_Changed">
                                    <ComboBoxItem Content="🚀 Gemini (Recommended)"/>
                                    <ComboBoxItem Content="⚡ GPT-5"/>
                                    <ComboBoxItem Content="✨ Claude"/>
                                    <ComboBoxItem Content="🧪 Ollama (Local, Experimental)"/>
                                    <ComboBoxItem Content="🌐 OpenRouter (Any Model)"/>
                                    <ComboBoxItem Content="🧪 Dummy (Testing)"/>
                                </ComboBox>

                                <!-- Gemini API Key -->
                                <Grid x:Name="GeminiApiKeyPanel">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Gemini API Key" FontSize="12" 
                                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="GeminiApiKeyBox" Grid.Column="0" Margin="0,0,8,0"
                                                 TextChanged="Setting_Changed"/>
                                        <TextBlock x:Name="GeminiApiKeyStatus" Grid.Column="1" Text="●" FontSize="16"
                                                   VerticalAlignment="Center" Foreground="{StaticResource TextMuted}"
                                                   ToolTip="API key status"/>
                                    </Grid>
                                </Grid>

                                <!-- GPT-5 API Key -->
                                <Grid x:Name="Gpt5ApiKeyPanel" Visibility="Collapsed">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="OpenAI API Key" FontSize="12" 
                                               Foreground="{StaticResource TextSecondary}" Margin="0,12,0,4"/>
                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="Gpt5ApiKeyBox" Grid.Column="0" Margin="0,0,8,0" 
                                                 TextChanged="Setting_Changed"/>
                                        <TextBlock x:Name="Gpt5ApiKeyStatus" Grid.Column="1" Text="●" FontSize="16"
                                                   VerticalAlignment="Center" Foreground="{StaticResource TextMuted}"
                                                   ToolTip="API key status"/>
                                    </Grid>
                                </Grid>

                                <!-- Claude API Key -->
                                <Grid x:Name="ClaudeApiKeyPanel" Visibility="Collapsed">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Claude API Key" FontSize="12" 
                                               Foreground="{StaticResource TextSecondary}" Margin="0,12,0,4"/>
                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="ClaudeApiKeyBox" Grid.Column="0" Margin="0,0,8,0" 
                                                 TextChanged="Setting_Changed"/>
                                        <TextBlock x:Name="ClaudeApiKeyStatus" Grid.Column="1" Text="●" FontSize="16"
                                                   VerticalAlignment="Center" Foreground="{StaticResource TextMuted}"
                                                   ToolTip="API key status"/>
                                    </Grid>
                                </Grid>

                                <!-- Gemini Model -->
                                <StackPanel x:Name="GeminiModelPanel">
                                    <TextBlock Text="Model" FontSize="12" Foreground="{StaticResource TextSecondary}"
                                               Margin="0,12,0,4"/>
                                    <ComboBox x:Name="GeminiModelCombo" SelectionChanged="Setting_Changed">
                                        <ComboBoxItem Content="gemini-3.1-flash-lite-preview (Fastest)" Tag="gemini-3.1-flash-lite-preview"/>
                                        <ComboBoxItem Content="gemini-3-flash-preview (Fast)" Tag="gemini-3-flash-preview"/>
                                        <ComboBoxItem Content="gemini-2.5-flash (Stable)" Tag="gemini-2.5-flash"/>
                                        <ComboBoxItem Content="gemini-2.5-pro (Smart)" Tag="gemini-2.5-pro"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- GPT-5 Model -->
                                <StackPanel x:Name="Gpt5ModelPanel" Visibility="Collapsed">
                                    <TextBlock Text="Model" FontSize="12" Foreground="{StaticResource TextSecondary}"
                                               Margin="0,12,0,4"/>
                                    <ComboBox x:Name="Gpt5ModelCombo" SelectionChanged="Setting_Changed">
                                        <ComboBoxItem Content="gpt-5.4-nano (Fastest)" Tag="gpt-5.4-nano"/>
                                        <ComboBoxItem Content="gpt-5.4-mini (Balanced)" Tag="gpt-5.4-mini"/>
                                        <ComboBoxItem Content="gpt-5.4 (Smart)" Tag="gpt-5.4"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Claude Model -->
                                <StackPanel x:Name="ClaudeModelPanel" Visibility="Collapsed">
                                    <TextBlock Text="Model" FontSize="12" Foreground="{StaticResource TextSecondary}"
                                               Margin="0,12,0,4"/>
                                    <ComboBox x:Name="ClaudeModelCombo" SelectionChanged="Setting_Changed">
                                        <ComboBoxItem Content="claude-haiku-4-5 (Fast)" Tag="claude-haiku-4-5-20251001"/>
                                        <ComboBoxItem Content="claude-sonnet-4-5 (Smart)" Tag="claude-sonnet-4-5-20250214"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Ollama Settings (no API key needed) -->
                                <StackPanel x:Name="OllamaPanel" Visibility="Collapsed">
                                    <!-- Experimental warning -->
                                    <Border Background="#1AFFA500" BorderBrush="#80FFA500" BorderThickness="1"
                                            CornerRadius="6" Padding="10,8" Margin="0,12,0,0">
                                        <StackPanel>
                                            <TextBlock Text="🧪 Experimental — Use at your own risk"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="#FFFFA500" Margin="0,0,0,4"/>
                                            <TextBlock TextWrapping="Wrap" FontSize="11"
                                                       Foreground="{StaticResource TextMuted}"
                                                       Text="Local model quality varies significantly by model size and hardware. Completion accuracy is not guaranteed. Requires Ollama installed and running locally. Not recommended for general use."/>
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="Model" FontSize="12" Foreground="{StaticResource TextSecondary}"
                                               Margin="0,12,0,4"/>
                                    <ComboBox x:Name="OllamaModelCombo" SelectionChanged="Setting_Changed">
                                        <ComboBoxItem Content="qwen3:30b-a3b ★ Best (MoE, 14B quality at 8B speed)" Tag="qwen3:30b-a3b"/>
                                        <ComboBoxItem Content="qwen3:8b (8B dense, fast)" Tag="qwen3:8b"/>
                                        <ComboBoxItem Content="mistral:7b (fast, great prose)" Tag="mistral:7b"/>
                                        <ComboBoxItem Content="qwen2.5:7b (solid, well-tested)" Tag="qwen2.5:7b"/>
                                        <ComboBoxItem Content="llama3.1:8b (Meta 8B)" Tag="llama3.1:8b"/>
                                        <ComboBoxItem Content="llama3.2:latest (3B, fastest)" Tag="llama3.2:latest"/>
                                        <ComboBoxItem Content="qwen2.5:0.5b-base (tiny base model)" Tag="qwen2.5:0.5b-base"/>
                                    </ComboBox>
                                    
                                    <TextBlock Text="Ollama Endpoint" FontSize="12" Foreground="{StaticResource TextSecondary}"
                                               Margin="0,12,0,4"/>
                                    <TextBox x:Name="OllamaEndpointBox" TextChanged="Setting_Changed"/>
                                    
                                    <TextBlock x:Name="OllamaStatus" Text="● Checking..."
                                               FontSize="12" Foreground="{StaticResource TextMuted}"
                                               Margin="0,8,0,0"/>
                                </StackPanel>

                                <!-- OpenRouter Settings -->
                                <StackPanel x:Name="OpenRouterPanel" Visibility="Collapsed">

                                    <!-- API Key row -->
                                    <TextBlock Text="OpenRouter API Key" FontSize="12"
                                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="OpenRouterApiKeyBox" Grid.Column="0" Margin="0,0,8,0"
                                                 TextChanged="Setting_Changed"/>
                                        <TextBlock x:Name="OpenRouterApiKeyStatus" Grid.Column="1" Text="●"
                                                   FontSize="16" VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextMuted}"
                                                   ToolTip="API key status"/>
                                    </Grid>

                                    <!-- Model selector header: label + refresh button -->
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Model" FontSize="12"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   VerticalAlignment="Center"/>
                                        <Button x:Name="OpenRouterRefreshBtn" Grid.Column="1"
                                                Content="↻ Refresh" FontSize="11"
                                                Background="Transparent" Foreground="{StaticResource Accent}"
                                                BorderThickness="0" Padding="4,2" Cursor="Hand"
                                                Click="OpenRouterRefresh_Click"/>
                                    </Grid>

                                    <!-- Dynamic model list — populated in code-behind -->
                                    <!-- ⭐ = recommended for autocomplete; others work but vary in quality -->
                                    <ComboBox x:Name="OpenRouterModelCombo" Margin="0,0,0,4"
                                              SelectionChanged="OpenRouterModelCombo_SelectionChanged"/>

                                    <!-- Loading / error state label -->
                                    <TextBlock x:Name="OpenRouterModelStatus" FontSize="11"
                                               Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>

                                    <!-- Warning shown when a reasoning-first model is selected -->
                                    <TextBlock x:Name="OpenRouterReasoningWarning"
                                               Text="⚠ Reasoning model selected. These models have higher latency and inconsistent completion quality for autocomplete use."
                                               FontSize="11" TextWrapping="Wrap"
                                               Foreground="#F08830"
                                               Visibility="Collapsed" Margin="0,6,0,0"/>

                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Behavior Section -->
                        <Border Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Trigger Behavior" FontSize="14" FontWeight="SemiBold" 
                                           Foreground="{StaticResource TextPrimary}" Margin="0,0,0,4"/>
                                <TextBlock Text="Control when predictions appear" 
                                           Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,12"/>

                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Completion Length" FontSize="12" 
                                               Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                                </Grid>
                                <ComboBox x:Name="LengthCombo" Margin="0,0,0,16" SelectionChanged="Setting_Changed">
                                    <ComboBoxItem Content="📝 Brief (3-5 words)" Tag="brief"/>
                                    <ComboBoxItem Content="📄 Standard (8-15 words)" Tag="standard"/>
                                    <ComboBoxItem Content="📚 Extended (15-30 words)" Tag="extended"/>
                                    <ComboBoxItem Content="🔮 Unlimited (30-50 words)" Tag="unlimited"/>
                                </ComboBox>

                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="Min Characters Before Predicting" FontSize="12" 
                                               Foreground="{StaticResource TextSecondary}"/>
                                    <TextBlock x:Name="MinCharsLabel" Text="3" 
                                               Foreground="{StaticResource Accent}" FontWeight="SemiBold"
                                               FontSize="12" HorizontalAlignment="Right"/>
                                </Grid>
                                <Slider x:Name="MinCharsSlider" Minimum="1" Maximum="10" Value="3"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        ValueChanged="MinCharsSlider_Changed" Margin="0,0,0,12"/>

                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="Delay After Word (space, period...)" FontSize="12" 
                                               Foreground="{StaticResource TextSecondary}"/>
                                    <TextBlock x:Name="DebounceLabel" Text="300ms" 
                                               Foreground="{StaticResource Accent}" FontWeight="SemiBold"
                                               FontSize="12" HorizontalAlignment="Right"/>
                                </Grid>
                                <Slider x:Name="DebounceSlider" Minimum="100" Maximum="1500" Value="300"
                                        ValueChanged="DebounceSlider_Changed" Margin="0,0,0,12"/>

                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="Delay While Typing (mid-word)" FontSize="12" 
                                               Foreground="{StaticResource TextSecondary}"/>
                                    <TextBlock x:Name="FastDebounceLabel" Text="100ms" 
                                               Foreground="{StaticResource Accent}" FontWeight="SemiBold"
                                               FontSize="12" HorizontalAlignment="Right"/>
                                </Grid>
                                <Slider x:Name="FastDebounceSlider" Minimum="50" Maximum="500" Value="100"
                                        ValueChanged="FastDebounceSlider_Changed"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- QUALITY TAB -->
            <TabItem Header="✨ Quality">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,8,8,16">
                        
                        <Border Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Smart Features" FontSize="14" FontWeight="SemiBold" 
                                           Foreground="{StaticResource TextPrimary}" Margin="0,0,0,4"/>
                                <TextBlock Text="Advanced features that improve suggestion quality" 
                                           Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,12"/>

                                <!-- Rolling Context -->
                                <Border Background="{StaticResource BgInput}" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="🔄 Rolling Context" FontSize="13" 
                                                       Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold"/>
                                            <TextBlock Text="Remembers last 500 chars for topic continuity" 
                                                       Foreground="{StaticResource TextMuted}" FontSize="11" 
                                                       TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <CheckBox x:Name="RollingContextCheck" Grid.Column="1" IsChecked="True"
                                                  Checked="Setting_CheckChanged" Unchecked="Setting_CheckChanged"
                                                  VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <!-- Acceptance Learning -->
                                <Border Background="{StaticResource BgInput}" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="🎓 Learn From Acceptances" FontSize="13" 
                                                       Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold"/>
                                            <TextBlock Text="Matches your style using accepted completions" 
                                                       Foreground="{StaticResource TextMuted}" FontSize="11" 
                                                       TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <CheckBox x:Name="LearningEnabledCheck" Grid.Column="1" IsChecked="True"
                                                  Checked="Setting_CheckChanged" Unchecked="Setting_CheckChanged"
                                                  VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <!-- OCR -->
                                <Border Background="{StaticResource BgInput}" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="👁️ Screen Reading (OCR)" FontSize="13" 
                                                       Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold"/>
                                            <TextBlock Text="Captures visible text for better context" 
                                                       Foreground="{StaticResource TextMuted}" FontSize="11" 
                                                       TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <CheckBox x:Name="OcrEnabledCheck" Grid.Column="1" IsChecked="True"
                                                  Checked="Setting_CheckChanged" Unchecked="Setting_CheckChanged"
                                                  VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <!-- App Detection -->
                                <Border Background="{StaticResource BgInput}" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="🎯 App-Aware Tone" FontSize="13" 
                                                       Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold"/>
                                            <TextBlock Text="Adjusts style: casual (chat), formal (email), precise (code)" 
                                                       Foreground="{StaticResource TextMuted}" FontSize="11" 
                                                       TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="Always On" FontSize="11" 
                                                   Foreground="{StaticResource Success}" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Suggestions Per Request -->
                        <Border Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Suggestions Per Request" FontSize="14" FontWeight="SemiBold" 
                                           Foreground="{StaticResource TextPrimary}" Margin="0,0,0,4"/>
                                <TextBlock Text="More suggestions = more choices (Ctrl+Up/Down) but costs more tokens" 
                                           Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,12"/>

                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="1 = Fastest / Cheapest" FontSize="11" 
                                               Foreground="{StaticResource TextMuted}" HorizontalAlignment="Left"/>
                                    <TextBlock x:Name="SuggestionsLabel" Text="3" 
                                               Foreground="{StaticResource Accent}" FontWeight="SemiBold"
                                               FontSize="14" HorizontalAlignment="Center"/>
                                    <TextBlock Text="5 = Most Options" FontSize="11" 
                                               Foreground="{StaticResource TextMuted}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Slider x:Name="SuggestionsSlider" Minimum="1" Maximum="5" Value="3"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        ValueChanged="SuggestionsSlider_Changed"/>
                            </StackPanel>
                        </Border>

                        <!-- Creativity Override -->
                        <Border Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Base Creativity (Temperature)" FontSize="14" FontWeight="SemiBold" 
                                           Foreground="{StaticResource TextPrimary}" Margin="0,0,0,4"/>
                                <TextBlock Text="Lower = more predictable, Higher = more creative. Auto-adjusts per app." 
                                           Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,12"/>
                                
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="Conservative" FontSize="11" 
                                               Foreground="{StaticResource TextMuted}" HorizontalAlignment="Left"/>
                                    <TextBlock x:Name="TempLabel" Text="0.3" 
                                               Foreground="{StaticResource Accent}" FontWeight="SemiBold"
                                               FontSize="14" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Creative" FontSize="11" 
                                               Foreground="{StaticResource TextMuted}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Slider x:Name="TempSlider" Minimum="0" Maximum="1.0" Value="0.3"
                                        ValueChanged="TempSlider_Changed" TickFrequency="0.1"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- LEARNING TAB -->
            <TabItem Header="📊 Learning">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,8,8,16">
                        
                        <Border Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Learning Statistics" FontSize="14" FontWeight="SemiBold" 
                                           Foreground="{StaticResource TextPrimary}" Margin="0,0,0,4"/>
                                <TextBlock Text="How Keystroke has learned your writing style" 
                                           Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,16"/>

                                <!-- Stats Grid -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="{StaticResource BgInput}" CornerRadius="8"
                                            Padding="12" Margin="0,0,8,0">
                                        <StackPanel>
                                            <TextBlock x:Name="StatsTotalAccepted" Text="0" FontSize="28"
                                                       FontWeight="Bold" Foreground="{StaticResource Accent}"/>
                                            <TextBlock Text="Accepted" Foreground="{StaticResource TextMuted}"
                                                       FontSize="11"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Accept Rate replaces the less-useful Categories count;
                                         category breakdown is already visible in the bars below. -->
                                    <Border Grid.Column="1" Background="{StaticResource BgInput}" CornerRadius="8"
                                            Padding="12" Margin="4,0,4,0">
                                        <StackPanel>
                                            <TextBlock x:Name="StatsAcceptRate" Text="—" FontSize="28"
                                                       FontWeight="Bold" Foreground="{StaticResource Success}"/>
                                            <TextBlock Text="Accept Rate" Foreground="{StaticResource TextMuted}"
                                                       FontSize="11"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2" Background="{StaticResource BgInput}" CornerRadius="8"
                                            Padding="12" Margin="8,0,0,0">
                                        <StackPanel>
                                            <TextBlock x:Name="StatsLastActivity" Text="-" FontSize="14"
                                                       FontWeight="Bold" Foreground="{StaticResource TextPrimary}"
                                                       VerticalAlignment="Center" Margin="0,8,0,0"/>
                                            <TextBlock Text="Last Activity" Foreground="{StaticResource TextMuted}"
                                                       FontSize="11"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Category Intelligence Cards (Sub-Phase D) -->
                                <TextBlock Text="Learning Intelligence by Category" FontSize="12"
                                           Foreground="{StaticResource TextSecondary}" Margin="0,0,0,8"/>
                                <StackPanel x:Name="CategoryBreakdownPanel">
                                    <!-- Dynamically populated with CreateIntelligenceCard() -->
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Data Management -->
                        <Border Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Data Management" FontSize="14" FontWeight="SemiBold" 
                                           Foreground="{StaticResource TextPrimary}" Margin="0,0,0,12"/>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Reset Learning Data" FontSize="13" 
                                                   Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold"/>
                                        <TextBlock Text="Clears all accepted completions and starts fresh" 
                                                   Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Reset" Style="{StaticResource SecondaryButton}"
                                            Click="ResetLearning_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Style Profile -->
                        <Border Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Writing Style Profile" FontSize="14" FontWeight="SemiBold" 
                                           Foreground="{StaticResource TextPrimary}" Margin="0,0,0,4"/>
                                <TextBlock Text="Periodically analyzes your accepted completions to learn your unique writing style" 
                                           Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,12"/>

                                <Border Background="{StaticResource BgInput}" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="✨ Style Profile" FontSize="13" 
                                                       Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold"/>
                                            <TextBlock Text="Learns your tone, vocabulary, and sentence structure" 
                                                       Foreground="{StaticResource TextMuted}" FontSize="11" 
                                                       TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <CheckBox x:Name="StyleProfileCheck" Grid.Column="1" IsChecked="True"
                                                  Checked="StyleProfileCheck_Changed" Unchecked="StyleProfileCheck_Changed"
                                                  VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="Update Frequency (acceptances between updates)" FontSize="12" 
                                               Foreground="{StaticResource TextSecondary}"/>
                                    <TextBlock x:Name="StyleProfileIntervalLabel" Text="30" 
                                               Foreground="{StaticResource Accent}" FontWeight="SemiBold"
                                               FontSize="12" HorizontalAlignment="Right"/>
                                </Grid>
                                <Slider x:Name="StyleProfileIntervalSlider" Minimum="10" Maximum="100" Value="30"
                                        IsSnapToTickEnabled="True" TickFrequency="5"
                                        ValueChanged="StyleProfileIntervalSlider_Changed"/>

                                 <TextBlock x:Name="StyleProfileStatus" Text="" FontSize="11"
                                            Foreground="{StaticResource TextMuted}" Margin="0,8,0,0"/>

                                 <!-- Progress Ring -->
                                 <Grid x:Name="StyleProgressPanel" Margin="0,16,0,12"
                                       HorizontalAlignment="Center" Visibility="Collapsed">
                                     <Grid.ColumnDefinitions>
                                         <ColumnDefinition Width="Auto"/>
                                         <ColumnDefinition Width="*"/>
                                     </Grid.ColumnDefinitions>

                                     <!-- Ring -->
                                     <Grid Width="80" Height="80">
                                         <Ellipse Width="80" Height="80"
                                                  Stroke="#30363D" StrokeThickness="6"
                                                  Fill="Transparent"/>
                                         <Ellipse x:Name="ProgressArc"
                                                  Width="80" Height="80"
                                                  Stroke="#2F81F7" StrokeThickness="6"
                                                  Fill="Transparent"
                                                  StrokeDashArray="0 38.746"
                                                  StrokeDashOffset="0"
                                                  RenderTransformOrigin="0.5,0.5">
                                             <Ellipse.RenderTransform>
                                                 <RotateTransform Angle="-90"/>
                                             </Ellipse.RenderTransform>
                                         </Ellipse>
                                         <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                             <TextBlock x:Name="ProgressCount" Text="0/30"
                                                        FontSize="14" FontWeight="SemiBold"
                                                        Foreground="#F0F6FC" HorizontalAlignment="Center"/>
                                             <TextBlock x:Name="ProgressLabel" Text="acceptances"
                                                        FontSize="9" Foreground="#6E7681"
                                                        HorizontalAlignment="Center"/>
                                         </StackPanel>
                                     </Grid>

                                     <!-- Legend -->
                                     <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                                         <TextBlock x:Name="ProgressMessage" Text="until next profile update"
                                                    FontSize="12" Foreground="#8B949E"/>
                                         <TextBlock x:Name="ProgressGenerated" Text=""
                                                    FontSize="11" Foreground="#238636" Margin="0,4,0,0"/>
                                     </StackPanel>
                                 </Grid>

                                 <!-- Category Badges -->
                                 <WrapPanel x:Name="CategoryBadgesPanel" Margin="0,0,0,8" Orientation="Horizontal"/>
                            </StackPanel>
                        </Border>

                        <!-- Vocabulary Fingerprint -->
                        <Border Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Vocabulary Fingerprint" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}" Margin="0,0,0,4"/>
                                <TextBlock Text="Analyses your accepted completions to learn your personal word choices, phrase patterns, and sentence structure — no AI call required"
                                           Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,12"
                                           TextWrapping="Wrap"/>

                                <!-- Status row -->
                                <TextBlock x:Name="VocabProfileStatus" Text="No fingerprint generated yet."
                                           Foreground="{StaticResource TextMuted}" FontSize="11"
                                           Margin="0,0,0,10" TextWrapping="Wrap"/>

                                <!-- Per-category badges -->
                                <WrapPanel x:Name="VocabCategoryBadgesPanel" Orientation="Horizontal"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- APPEARANCE TAB -->
            <TabItem Header="🎨 Appearance">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,8,8,16">
                        <Border Style="{StaticResource CardStyle}" Padding="16">
                            <StackPanel>
                                <TextBlock Text="Panel Theme" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}" Margin="0,0,0,4"/>
                                <TextBlock Text="Sets the accent color of the autocomplete suggestion panel"
                                           Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,24"/>

                                <UniformGrid Columns="5" HorizontalAlignment="Left">

                                    <!-- Midnight -->
                                    <Button Tag="midnight" Click="Swatch_Click"
                                            Style="{StaticResource SwatchButton}" Margin="0,0,20,0">
                                        <StackPanel>
                                            <Grid Width="52" Height="52" Margin="0,0,0,8">
                                                <Ellipse x:Name="SwatchRingMidnight"
                                                         Stroke="Transparent" StrokeThickness="3"/>
                                                <Ellipse Fill="#5050E8" Width="38" Height="38"/>
                                            </Grid>
                                            <TextBlock Text="Midnight" FontSize="11" FontFamily="Segoe UI"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Ember -->
                                    <Button Tag="ember" Click="Swatch_Click"
                                            Style="{StaticResource SwatchButton}" Margin="0,0,20,0">
                                        <StackPanel>
                                            <Grid Width="52" Height="52" Margin="0,0,0,8">
                                                <Ellipse x:Name="SwatchRingEmber"
                                                         Stroke="Transparent" StrokeThickness="3"/>
                                                <Ellipse Fill="#D06010" Width="38" Height="38"/>
                                            </Grid>
                                            <TextBlock Text="Ember" FontSize="11" FontFamily="Segoe UI"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Forest -->
                                    <Button Tag="forest" Click="Swatch_Click"
                                            Style="{StaticResource SwatchButton}" Margin="0,0,20,0">
                                        <StackPanel>
                                            <Grid Width="52" Height="52" Margin="0,0,0,8">
                                                <Ellipse x:Name="SwatchRingForest"
                                                         Stroke="Transparent" StrokeThickness="3"/>
                                                <Ellipse Fill="#209A50" Width="38" Height="38"/>
                                            </Grid>
                                            <TextBlock Text="Forest" FontSize="11" FontFamily="Segoe UI"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Rose -->
                                    <Button Tag="rose" Click="Swatch_Click"
                                            Style="{StaticResource SwatchButton}" Margin="0,0,20,0">
                                        <StackPanel>
                                            <Grid Width="52" Height="52" Margin="0,0,0,8">
                                                <Ellipse x:Name="SwatchRingRose"
                                                         Stroke="Transparent" StrokeThickness="3"/>
                                                <Ellipse Fill="#C83898" Width="38" Height="38"/>
                                            </Grid>
                                            <TextBlock Text="Rose" FontSize="11" FontFamily="Segoe UI"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Slate -->
                                    <Button Tag="slate" Click="Swatch_Click"
                                            Style="{StaticResource SwatchButton}">
                                        <StackPanel>
                                            <Grid Width="52" Height="52" Margin="0,0,0,8">
                                                <Ellipse x:Name="SwatchRingSlate"
                                                         Stroke="Transparent" StrokeThickness="3"/>
                                                <Ellipse Fill="#586878" Width="38" Height="38"/>
                                            </Grid>
                                            <TextBlock Text="Slate" FontSize="11" FontFamily="Segoe UI"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                </UniformGrid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ADVANCED TAB -->
            <TabItem Header="⚙️ Advanced">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,8,8,16">

                        <!-- Beta Features -->
                        <Border Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Beta Features" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}" Margin="0,0,0,4"/>
                                <TextBlock Text="Experimental features that may not work in all apps."
                                           Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,12"/>

                                <CheckBox x:Name="GhostTextCheck" Content="Inline ghost text"
                                          Foreground="{StaticResource TextPrimary}" FontSize="13"
                                          Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                                <TextBlock Text="Show faded autocomplete text directly at the cursor position (like VS Code Copilot). Works best in traditional Win32 apps — Notepad, Word, Outlook. Falls back to mouse position in Chromium-based apps."
                                           Foreground="{StaticResource TextMuted}" FontSize="11"
                                           TextWrapping="Wrap" Margin="20,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}" Padding="16">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="System Prompt" FontSize="14" FontWeight="SemiBold" 
                                               Foreground="{StaticResource TextPrimary}"/>
                                    <Button Grid.Column="1" Content="Reset to Default" Style="{StaticResource SecondaryButton}" 
                                            Click="ResetPrompt_Click"/>
                                </Grid>
                                <TextBlock Text="Instructions given to the AI. Only change if you know what you're doing." 
                                           Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,12"/>
                                
                                <TextBox x:Name="PromptBox" AcceptsReturn="True" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" Height="350"
                                         FontFamily="Consolas" FontSize="12" TextChanged="Setting_Changed"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" 
                BorderThickness="0,1,0,0" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Changes save automatically" 
                               Foreground="{StaticResource TextMuted}" FontSize="12" 
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="SaveStatus" Text=" ✓ Saved" 
                               Foreground="{StaticResource Success}" FontSize="12" 
                               FontWeight="SemiBold" VerticalAlignment="Center" Opacity="0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Done" Style="{StaticResource PrimaryButton}" Click="Done_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
