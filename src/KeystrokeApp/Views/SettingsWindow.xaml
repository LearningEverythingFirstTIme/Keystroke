<Window x:Class="KeystrokeApp.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Keystroke Settings"
        Height="760"
        Width="1180"
        MinHeight="720"
        MinWidth="1080"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#0B1220">

    <Window.Resources>
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="White"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#111827"/>

        <SolidColorBrush x:Key="BgWindow" Color="#0B1220"/>
        <SolidColorBrush x:Key="BgSidebar" Color="#0F172A"/>
        <SolidColorBrush x:Key="BgCard" Color="#111C2E"/>
        <SolidColorBrush x:Key="BgCardSoft" Color="#172338"/>
        <SolidColorBrush x:Key="BgInput" Color="#17263B"/>
        <SolidColorBrush x:Key="BgHover" Color="#223551"/>
        <SolidColorBrush x:Key="BgPreview" Color="#0F1A2B"/>
        <SolidColorBrush x:Key="Accent" Color="#5EA6FF"/>
        <SolidColorBrush x:Key="Success" Color="#34C38F"/>
        <SolidColorBrush x:Key="Warning" Color="#F3A74F"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#CBD5E1"/>
        <SolidColorBrush x:Key="TextMuted" Color="#8CA0BB"/>
        <SolidColorBrush x:Key="Border" Color="#22324A"/>
        <SolidColorBrush x:Key="BorderStrong" Color="#39506E"/>
        <SolidColorBrush x:Key="PrivacyTint" Color="#3B2A20"/>
        <SolidColorBrush x:Key="PrivacyBorder" Color="#6A4C3B"/>
        <SolidColorBrush x:Key="LearningTint" Color="#182E2B"/>
        <SolidColorBrush x:Key="LearningBorder" Color="#245D50"/>
        <SolidColorBrush x:Key="ExperimentalTint" Color="#33250F"/>
        <SolidColorBrush x:Key="ExperimentalBorder" Color="#7A5922"/>

        <Style TargetType="TextBlock" x:Key="SectionTitleStyle">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="SectionIntroStyle">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style TargetType="Border" x:Key="SoftCardStyle" BasedOn="{StaticResource CardStyle}">
            <Setter Property="Background" Value="{StaticResource BgCardSoft}"/>
        </Style>

        <Style TargetType="Border" x:Key="PrivacyCardStyle" BasedOn="{StaticResource CardStyle}">
            <Setter Property="Background" Value="{StaticResource PrivacyTint}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrivacyBorder}"/>
        </Style>

        <Style TargetType="Border" x:Key="LearningCardStyle" BasedOn="{StaticResource CardStyle}">
            <Setter Property="Background" Value="{StaticResource LearningTint}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LearningBorder}"/>
        </Style>

        <Style TargetType="Border" x:Key="ExperimentalCardStyle" BasedOn="{StaticResource CardStyle}">
            <Setter Property="Background" Value="{StaticResource ExperimentalTint}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ExperimentalBorder}"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="MainGrid" SnapsToDevicePixels="True">
                            <ToggleButton x:Name="DropDownToggle"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ComboBorder"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="32"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           FontSize="13"
                                                           VerticalAlignment="Center"
                                                           Margin="12,0,0,0"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <Path Grid.Column="1"
                                                      Fill="{StaticResource TextSecondary}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{StaticResource BorderStrong}"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade"
                                   StaysOpen="False">
                                <Border Background="White"
                                        BorderBrush="{StaticResource BorderStrong}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        MinWidth="{Binding ActualWidth, ElementName=MainGrid}"
                                        MaxHeight="360">
                                    <ScrollViewer Margin="4" Focusable="False">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ComboItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ComboItemBorder" Property="Background" Value="#E8F0FE"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ComboItemBorder" Property="Background" Value="#D2E3FC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BgHover}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderStrong}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="PillStyle" TargetType="Border">
            <Setter Property="Background" Value="#203047"/>
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>

        <Style x:Key="NavRadioStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="NavBorder"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14,12">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="#172338"/>
                                <Setter TargetName="NavBorder" Property="BorderBrush" Value="{StaticResource BorderStrong}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="#142238"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="SwitchCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="52" Height="30">
                            <Border x:Name="Track"
                                    Background="#415A77"
                                    CornerRadius="15"
                                    BorderBrush="#5A7696"
                                    BorderThickness="1"/>
                            <Ellipse x:Name="Thumb"
                                     Width="22"
                                     Height="22"
                                     Fill="White"
                                     Margin="4,0,0,0"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource Accent}"/>
                                <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,4,0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Track" Property="Opacity" Value="0.45"/>
                                <Setter TargetName="Thumb" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FeatureCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
            <Setter Property="Padding" Value="18"/>
        </Style>

        <Style x:Key="ThemeCardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="PresetButton" TargetType="Button">
            <Setter Property="Background" Value="#16263C"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BgWindow}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource BgSidebar}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="0,0,1,0">
            <DockPanel Margin="18">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Keystroke"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="24"
                               FontWeight="Bold"/>
                    <TextBlock Text="Settings"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="13"
                               Margin="0,4,0,24"/>

                    <RadioButton x:Name="NavOverviewButton" GroupName="SettingsNav" IsChecked="True" Checked="NavigateSection_Checked" Tag="Overview" Style="{StaticResource NavRadioStyle}">
                        <StackPanel>
                            <TextBlock Text="Overview"/>
                            <TextBlock Text="Quick read on how Keystroke feels right now" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavSuggestionsButton" GroupName="SettingsNav" Checked="NavigateSection_Checked" Tag="Suggestions" Style="{StaticResource NavRadioStyle}">
                        <StackPanel>
                            <TextBlock Text="Suggestions"/>
                            <TextBlock Text="Tune timing, length, and creativity" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavPersonalizationButton" GroupName="SettingsNav" Checked="NavigateSection_Checked" Tag="Personalization" Style="{StaticResource NavRadioStyle}">
                        <StackPanel>
                            <TextBlock Text="Personalization"/>
                            <TextBlock Text="Context, learning, and privacy choices" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavAppControlButton" GroupName="SettingsNav" Checked="NavigateSection_Checked" Tag="AppControl" Style="{StaticResource NavRadioStyle}">
                        <StackPanel>
                            <TextBlock Text="App Control"/>
                            <TextBlock Text="Choose exactly where Keystroke appears" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavAppearanceButton" GroupName="SettingsNav" Checked="NavigateSection_Checked" Tag="Appearance" Style="{StaticResource NavRadioStyle}">
                        <StackPanel>
                            <TextBlock Text="Appearance"/>
                            <TextBlock Text="Theme and preview styling" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavAdvancedButton" GroupName="SettingsNav" Checked="NavigateSection_Checked" Tag="Advanced" Style="{StaticResource NavRadioStyle}">
                        <StackPanel>
                            <TextBlock Text="Advanced"/>
                            <TextBlock Text="Engine setup, providers, and prompt" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

                <Border DockPanel.Dock="Bottom" Style="{StaticResource SoftCardStyle}" Margin="0,18,0,0">
                    <StackPanel>
                        <TextBlock Text="Auto-save is on" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold"/>
                        <TextBlock Text="Every change updates immediately. Use Done when you are finished."
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11"
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="24,22,24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="24" Margin="0,0,0,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="330"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,22,0">
                        <TextBlock x:Name="HeroTitleText" Text="Keystroke is tuned for balanced suggestions" Foreground="{StaticResource TextPrimary}" FontSize="28" FontWeight="SemiBold" TextWrapping="Wrap"/>
                        <TextBlock x:Name="HeroSubtitleText" Text="Fast enough for flow, grounded enough to stay out of your way." Foreground="{StaticResource TextSecondary}" FontSize="14" Margin="0,8,0,0" TextWrapping="Wrap"/>
                        <WrapPanel Margin="0,18,0,18">
                            <Border Style="{StaticResource PillStyle}"><TextBlock x:Name="HeroEngineStatusText" Text="Connected" Foreground="{StaticResource TextSecondary}" FontSize="11"/></Border>
                            <Border Style="{StaticResource PillStyle}"><TextBlock x:Name="HeroLearningStatusText" Text="Learning off" Foreground="{StaticResource TextSecondary}" FontSize="11"/></Border>
                            <Border Style="{StaticResource PillStyle}"><TextBlock x:Name="HeroContextStatusText" Text="Context on" Foreground="{StaticResource TextSecondary}" FontSize="11"/></Border>
                            <Border Style="{StaticResource PillStyle}"><TextBlock x:Name="HeroAppControlStatusText" Text="App control: open" Foreground="{StaticResource TextSecondary}" FontSize="11"/></Border>
                            <Border Style="{StaticResource PillStyle}"><TextBlock x:Name="HeroThemeStatusText" Text="Theme: Midnight" Foreground="{StaticResource TextSecondary}" FontSize="11"/></Border>
                        </WrapPanel>
                        <WrapPanel>
                            <Button x:Name="PresetMinimalBtn" Content="Minimal" Style="{StaticResource PresetButton}" Margin="0,0,10,0" Click="PresetMinimal_Click"/>
                            <Button x:Name="PresetBalancedBtn" Content="Balanced" Style="{StaticResource PresetButton}" Margin="0,0,10,0" Click="PresetBalanced_Click"/>
                            <Button x:Name="PresetMaxBtn" Content="Maximum" Style="{StaticResource PresetButton}" Click="PresetMaximum_Click"/>
                        </WrapPanel>
                    </StackPanel>

                    <Border Grid.Column="1" x:Name="PreviewBorder" Background="{StaticResource BgPreview}" BorderBrush="{StaticResource BorderStrong}" BorderThickness="1" CornerRadius="18" Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="PreviewAccentDot" Width="10" Height="10" Fill="{StaticResource Accent}" VerticalAlignment="Center"/>
                                <TextBlock Text="Live preview" Foreground="{StaticResource TextSecondary}" FontSize="12" FontWeight="SemiBold" Margin="8,0,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Margin="0,14,0,0">
                                <Border Background="#132238" CornerRadius="12" Padding="14" BorderBrush="#263B5B" BorderThickness="1">
                                    <TextBlock x:Name="PreviewInputText" Text="Can you send the latest draft when you have a minute" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" FontSize="13"/>
                                </Border>
                                <Border x:Name="PreviewSuggestionBubble" Margin="26,12,0,0" Background="#1C3150" CornerRadius="14" Padding="14" BorderBrush="#3B6293" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock x:Name="PreviewSuggestionText" Text=", I can tighten it up before we send it." Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                        <TextBlock x:Name="PreviewMetaText" Text="Extended • 3 suggestions • Balanced creativity" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <Grid>
                    <StackPanel x:Name="OverviewSection" Visibility="Visible">
                        <TextBlock Text="Overview" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="Start here for the simplest read on your current setup." Style="{StaticResource SectionIntroStyle}"/>

                        <Grid Margin="0,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="330"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,18,0">
                                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,18">
                                    <StackPanel>
                                        <TextBlock Text="How Keystroke feels" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="OverviewFeelText" Text="Balanced for fast, grounded suggestions." Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                        <WrapPanel Margin="0,16,0,0">
                                            <Border Style="{StaticResource PillStyle}"><TextBlock x:Name="OverviewLengthSummaryText" Text="Extended completions" Foreground="{StaticResource TextSecondary}" FontSize="11"/></Border>
                                            <Border Style="{StaticResource PillStyle}"><TextBlock x:Name="OverviewSpeedSummaryText" Text="300ms after words" Foreground="{StaticResource TextSecondary}" FontSize="11"/></Border>
                                            <Border Style="{StaticResource PillStyle}"><TextBlock x:Name="OverviewSuggestionSummaryText" Text="3 suggestions shown" Foreground="{StaticResource TextSecondary}" FontSize="11"/></Border>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,18">
                                    <StackPanel>
                                        <TextBlock Text="Current status" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="SemiBold"/>
                                        <Grid Margin="0,16,0,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Engine" Foreground="{StaticResource TextMuted}" Margin="0,0,0,10"/>
                                            <TextBlock x:Name="OverviewEngineStatusText" Grid.Column="1" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,10"/>
                                            <TextBlock Grid.Row="1" Text="Learning" Foreground="{StaticResource TextMuted}" Margin="0,0,0,10"/>
                                            <TextBlock x:Name="OverviewLearningStatusText" Grid.Row="1" Grid.Column="1" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,10"/>
                                            <TextBlock Grid.Row="2" Text="Privacy" Foreground="{StaticResource TextMuted}"/>
                                            <TextBlock x:Name="OverviewPrivacyStatusText" Grid.Row="2" Grid.Column="1" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <Border Style="{StaticResource PrivacyCardStyle}" Margin="0,0,0,18">
                                    <StackPanel>
                                        <TextBlock Text="Privacy at a glance" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="OverviewPrivacyDetailText" Text="Screen reading is on. Learning is off." Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SoftCardStyle}">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="App Control" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="SemiBold"/>
                                                <TextBlock x:Name="OverviewAppControlSummaryText" Text="Keystroke is available everywhere except blocked apps." Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                                <TextBlock x:Name="OverviewAppControlDetailText" Text="Open App Control to decide where the overlay should stay quiet." Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="Open App Control" Style="{StaticResource SecondaryButton}" Margin="18,0,0,0" VerticalAlignment="Top" Click="OpenAppControl_Click"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SoftCardStyle}" Margin="0,18,0,0">
                                    <StackPanel>
                                        <TextBlock Text="What changes most often" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="SemiBold"/>
                                        <TextBlock Text="Use Suggestions when you want Keystroke faster, shorter, or more cautious. Use Personalization when you want it to feel more like you. Use App Control when you want the overlay to stay out of specific apps."
                                                   Foreground="{StaticResource TextMuted}"
                                                   FontSize="12"
                                                   Margin="0,8,0,0"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <StackPanel x:Name="SuggestionsSection" Visibility="Collapsed">
                        <TextBlock Text="Suggestions" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="Tune when suggestions appear, how long they are, and how adventurous they feel." Style="{StaticResource SectionIntroStyle}"/>

                        <Border Style="{StaticResource CardStyle}" Margin="0,20,0,18">
                            <StackPanel>
                                <TextBlock Text="Suggestion length" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Choose how much Keystroke should finish for you in one go." Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,6,0,0"/>
                                <ComboBox x:Name="LengthCombo" Margin="0,16,0,0" SelectionChanged="Setting_Changed">
                                    <ComboBoxItem Content="Brief (3-5 words)" Tag="brief"/>
                                    <ComboBoxItem Content="Standard (8-15 words)" Tag="standard"/>
                                    <ComboBoxItem Content="Extended (15-30 words)" Tag="extended"/>
                                    <ComboBoxItem Content="Unlimited (30-50 words)" Tag="unlimited"/>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="When suggestions start" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="SemiBold"/>
                                    <Grid Margin="0,16,0,4">
                                        <TextBlock Text="Start predicting after" Foreground="{StaticResource TextSecondary}"/>
                                        <TextBlock x:Name="MinCharsLabel" Text="3" HorizontalAlignment="Right" Foreground="{StaticResource Accent}" FontWeight="SemiBold"/>
                                    </Grid>
                                    <Slider x:Name="MinCharsSlider" Minimum="1" Maximum="10" Value="3" IsSnapToTickEnabled="True" TickFrequency="1" ValueChanged="MinCharsSlider_Changed"/>
                                    <TextBlock Text="Higher values make Keystroke wait for more context before it steps in."
                                               Foreground="{StaticResource TextMuted}"
                                               FontSize="11"
                                               Margin="0,8,0,0"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="12,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="How many options to show" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="SemiBold"/>
                                    <Grid Margin="0,16,0,4">
                                        <TextBlock Text="1 = fastest" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                        <TextBlock x:Name="SuggestionsLabel" Text="3" HorizontalAlignment="Center" Foreground="{StaticResource Accent}" FontWeight="SemiBold"/>
                                        <TextBlock Text="5 = most options" HorizontalAlignment="Right" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                    </Grid>
                                    <Slider x:Name="SuggestionsSlider" Minimum="1" Maximum="5" Value="3" IsSnapToTickEnabled="True" TickFrequency="1" ValueChanged="SuggestionsSlider_Changed"/>
                                    <TextBlock Text="More options help when you like cycling choices. Fewer options keep latency and cost down."
                                               Foreground="{StaticResource TextMuted}"
                                               FontSize="11"
                                               Margin="0,8,0,0"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="Timing after punctuation" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="SemiBold"/>
                                    <Grid Margin="0,16,0,4">
                                        <TextBlock Text="Pause after a word or sentence" Foreground="{StaticResource TextSecondary}"/>
                                        <TextBlock x:Name="DebounceLabel" Text="300ms" HorizontalAlignment="Right" Foreground="{StaticResource Accent}" FontWeight="SemiBold"/>
                                    </Grid>
                                    <Slider x:Name="DebounceSlider" Minimum="100" Maximum="1500" Value="300" ValueChanged="DebounceSlider_Changed"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="12,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Timing while typing" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="SemiBold"/>
                                    <Grid Margin="0,16,0,4">
                                        <TextBlock Text="Pause in the middle of a thought" Foreground="{StaticResource TextSecondary}"/>
                                        <TextBlock x:Name="FastDebounceLabel" Text="100ms" HorizontalAlignment="Right" Foreground="{StaticResource Accent}" FontWeight="SemiBold"/>
                                    </Grid>
                                    <Slider x:Name="FastDebounceSlider" Minimum="50" Maximum="500" Value="100" ValueChanged="FastDebounceSlider_Changed"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Creativity" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Lower values stay safer. Higher values open up more expressive guesses." Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,6,0,0"/>
                                <Grid Margin="0,16,0,4">
                                    <TextBlock Text="Conservative" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                    <TextBlock x:Name="TempLabel" Text="0.3" HorizontalAlignment="Center" Foreground="{StaticResource Accent}" FontWeight="SemiBold"/>
                                    <TextBlock Text="Creative" HorizontalAlignment="Right" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                </Grid>
                                <Slider x:Name="TempSlider" Minimum="0" Maximum="1.0" Value="0.3" TickFrequency="0.1" ValueChanged="TempSlider_Changed"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel x:Name="PersonalizationSection" Visibility="Collapsed">
                        <TextBlock Text="Personalization" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="Choose how much context Keystroke uses and how much it learns from your writing." Style="{StaticResource SectionIntroStyle}"/>

                        <Grid Margin="0,20,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource FeatureCardStyle}" Margin="0,0,12,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Remember recent text" Foreground="{StaticResource TextPrimary}" FontSize="15" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="RollingContextStatusText" Text="Keeps continuity across the latest part of what you were writing." Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <CheckBox x:Name="RollingContextCheck" Grid.Column="1" Style="{StaticResource SwitchCheckBoxStyle}" Checked="Setting_CheckChanged" Unchecked="Setting_CheckChanged" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource PrivacyCardStyle}" Margin="12,0,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Use screen context" Foreground="{StaticResource TextPrimary}" FontSize="15" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="OcrStatusText" Text="Reads visible text on screen so suggestions stay grounded in what you are looking at." Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <CheckBox x:Name="OcrEnabledCheck" Grid.Column="1" Style="{StaticResource SwitchCheckBoxStyle}" Checked="Setting_CheckChanged" Unchecked="Setting_CheckChanged" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" x:Name="LearningFeatureCard" Style="{StaticResource LearningCardStyle}" Margin="0,0,12,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Learn from accepted suggestions" Foreground="{StaticResource TextPrimary}" FontSize="15" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="LearningFeatureStatusText" Text="Keystroke can use your accepted completions to better match your writing." Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <CheckBox x:Name="LearningEnabledCheck" Grid.Column="1" Style="{StaticResource SwitchCheckBoxStyle}" Checked="Setting_CheckChanged" Unchecked="Setting_CheckChanged" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1" x:Name="StyleProfileCard" Style="{StaticResource CardStyle}" Margin="12,0,0,0">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Style profile" Foreground="{StaticResource TextPrimary}" FontSize="15" FontWeight="SemiBold"/>
                                            <TextBlock x:Name="StyleProfileFeatureText" Text="Builds a writing profile over time so phrasing and tone feel more like you." Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <CheckBox x:Name="StyleProfileCheck" Grid.Column="1" Style="{StaticResource SwitchCheckBoxStyle}" Checked="StyleProfileCheck_Changed" Unchecked="StyleProfileCheck_Changed" VerticalAlignment="Center"/>
                                    </Grid>

                                    <Grid Margin="0,16,0,4">
                                        <TextBlock Text="Update after this many accepts" Foreground="{StaticResource TextSecondary}"/>
                                        <TextBlock x:Name="StyleProfileIntervalLabel" Text="30" HorizontalAlignment="Right" Foreground="{StaticResource Accent}" FontWeight="SemiBold"/>
                                    </Grid>
                                    <Slider x:Name="StyleProfileIntervalSlider" Minimum="10" Maximum="100" Value="30" TickFrequency="5" IsSnapToTickEnabled="True" ValueChanged="StyleProfileIntervalSlider_Changed"/>
                                    <TextBlock x:Name="StyleProfileDependencyText" Text="Needs learning to be on." Foreground="{StaticResource Warning}" FontSize="11" Margin="0,10,0,0" Visibility="Collapsed"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock Text="App-aware tone" Foreground="{StaticResource TextPrimary}" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="Keystroke always adapts across chat, email, code, browser, terminal, and document contexts." Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                <Border Style="{StaticResource PillStyle}" Margin="0,14,0,0" HorizontalAlignment="Left">
                                    <TextBlock Text="Always on" Foreground="{StaticResource Success}" FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="330"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,18,0">
                                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,18">
                                    <StackPanel>
                                        <TextBlock Text="Learning snapshot" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="SemiBold"/>
                                        <Grid Margin="0,16,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="{StaticResource BgInput}" CornerRadius="14" Padding="14" Margin="0,0,8,0">
                                                <StackPanel>
                                                    <TextBlock x:Name="StatsTotalAccepted" Text="0" FontSize="28" FontWeight="Bold" Foreground="{StaticResource Accent}"/>
                                                    <TextBlock Text="Accepted" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Column="1" Background="{StaticResource BgInput}" CornerRadius="14" Padding="14" Margin="4,0">
                                                <StackPanel>
                                                    <TextBlock x:Name="StatsAcceptRate" Text="-" FontSize="28" FontWeight="Bold" Foreground="{StaticResource Success}"/>
                                                    <TextBlock Text="Accept rate" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Column="2" Background="{StaticResource BgInput}" CornerRadius="14" Padding="14" Margin="8,0,0,0">
                                                <StackPanel>
                                                    <TextBlock x:Name="StatsLastActivity" Text="Never" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,5,0,0"/>
                                                    <TextBlock Text="Last activity" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="By category" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,18,0,8"/>
                                        <StackPanel x:Name="CategoryBreakdownPanel"/>
                                        <TextBlock Text="Top contexts" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,18,0,8"/>
                                        <StackPanel x:Name="ContextBreakdownPanel"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Data management" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="SemiBold"/>
                                            <Button Grid.Column="1" Content="Reset learning data" Style="{StaticResource SecondaryButton}" Click="ResetLearning_Click"/>
                                        </Grid>
                                        <TextBlock Text="Clear saved completions and rebuild your profile from scratch if Keystroke has drifted." Foreground="{StaticResource TextMuted}" FontSize="12" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <Border Style="{StaticResource LearningCardStyle}" Margin="0,0,0,18">
                                    <StackPanel>
                                        <TextBlock Text="Style profile progress" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="StyleProfileStatus" Text="" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                        <Grid x:Name="StyleProgressPanel" Margin="0,16,0,12" Visibility="Collapsed">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid Width="88" Height="88">
                                                <Ellipse Width="88" Height="88" Stroke="#29405D" StrokeThickness="7" Fill="Transparent"/>
                                                <Ellipse x:Name="ProgressArc" Width="88" Height="88" Stroke="{StaticResource Accent}" StrokeThickness="7" Fill="Transparent" StrokeDashArray="0 38.746" RenderTransformOrigin="0.5,0.5">
                                                    <Ellipse.RenderTransform>
                                                        <RotateTransform Angle="-90"/>
                                                    </Ellipse.RenderTransform>
                                                </Ellipse>
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock x:Name="ProgressCount" Text="0/30" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center"/>
                                                    <TextBlock x:Name="ProgressLabel" Text="accepts" FontSize="9" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                                                <TextBlock x:Name="ProgressMessage" Text="until next profile update" Foreground="{StaticResource TextSecondary}" FontSize="12" TextWrapping="Wrap"/>
                                                <TextBlock x:Name="ProgressGenerated" Text="" Foreground="{StaticResource Success}" FontSize="11" Margin="0,6,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                        <WrapPanel x:Name="CategoryBadgesPanel"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SoftCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Vocabulary fingerprint" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="VocabProfileStatus" Text="No fingerprint generated yet." Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,8,0,10" TextWrapping="Wrap"/>
                                        <WrapPanel x:Name="VocabCategoryBadgesPanel"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <StackPanel x:Name="AppControlSection" Visibility="Collapsed">
                        <TextBlock Text="App Control" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="Decide exactly where Keystroke is welcome so you can keep it on without second-guessing the overlay." Style="{StaticResource SectionIntroStyle}"/>

                        <Border Style="{StaticResource CardStyle}" Margin="0,20,0,18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="280"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,18,0">
                                    <TextBlock Text="Per-app availability" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="SemiBold"/>
                                    <TextBlock Text="Use this when you want Keystroke everywhere except a few noisy apps, or only inside a short trusted list like Discord and Slack." Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                    <ComboBox x:Name="AppFilteringModeCombo" Margin="0,16,0,0" SelectionChanged="AppFilteringModeCombo_Changed">
                                        <ComboBoxItem Tag="allow_all_except_blocked">All apps except blocked ones</ComboBoxItem>
                                        <ComboBoxItem Tag="allow_listed_only">Only listed apps</ComboBoxItem>
                                    </ComboBox>
                                    <TextBlock x:Name="AppFilteringDescriptionText" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,10,0,0" TextWrapping="Wrap"/>
                                </StackPanel>

                                <Border Grid.Column="1" Style="{StaticResource SoftCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Quick tips" Foreground="{StaticResource TextPrimary}" FontSize="15" FontWeight="SemiBold"/>
                                        <TextBlock Text="Block games, remote desktops, terminals, or anything fullscreen if the overlay feels distracting." Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,10,0,0" TextWrapping="Wrap"/>
                                        <TextBlock Text="Use allow-list mode if you only want Keystroke in a few communication apps." Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                        <TextBlock Text="Use “Add last” for the most recent app you were in, or the running-app picker when you want to choose explicitly." Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource SoftCardStyle}" Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="Last app you were using" Foreground="{StaticResource TextPrimary}" FontSize="15" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="LastExternalAppText" Text="No recent app captured yet." Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,10,0,0" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="LastExternalAppMetaText" Text="" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="LastExternalAppHintText" Text="Focus another app before opening Settings, or use the running-app picker on the right." Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                    <WrapPanel Margin="0,14,0,0">
                                        <Button Content="Block last app" Style="{StaticResource SecondaryButton}" Click="AddLastAppToBlocked_Click" Margin="0,0,10,0"/>
                                        <Button Content="Allow last app" Style="{StaticResource SecondaryButton}" Click="AddLastAppToAllowed_Click"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource SoftCardStyle}" Margin="12,0,0,0">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Running app picker" Foreground="{StaticResource TextPrimary}" FontSize="15" FontWeight="SemiBold"/>
                                        <Button Grid.Column="1" Content="Refresh" Style="{StaticResource SecondaryButton}" Click="RefreshAppPicker_Click"/>
                                    </Grid>
                                    <TextBlock Text="Pick a visible app from the current desktop session when you want an explicit target." Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                    <ComboBox x:Name="RunningAppsCombo" Margin="0,14,0,0" SelectionChanged="RunningAppsCombo_Changed"/>
                                    <TextBlock x:Name="RunningAppsSelectionDetailText" Text="Select an app to see more detail here." Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                    <WrapPanel Margin="0,14,0,0">
                                        <Button Content="Block selected" Style="{StaticResource SecondaryButton}" Click="AddSelectedAppToBlocked_Click" Margin="0,0,10,0"/>
                                        <Button Content="Allow selected" Style="{StaticResource SecondaryButton}" Click="AddSelectedAppToAllowed_Click"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border x:Name="BlockedAppsCard" Grid.Column="0" Background="{StaticResource BgInput}" CornerRadius="16" Padding="16" Margin="0,0,12,0">
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Blocked apps" Foreground="{StaticResource TextPrimary}" FontSize="14" FontWeight="SemiBold"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="Add last" Style="{StaticResource SecondaryButton}" Click="AddCurrentBlockedApp_Click" Margin="0,0,8,0"/>
                                            <Button Content="Clear" Style="{StaticResource SecondaryButton}" Click="ClearBlockedApps_Click"/>
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Text="One process name per line. Great for games, fullscreen apps, or anything where the overlay is distracting." Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,10" TextWrapping="Wrap"/>
                                    <TextBox x:Name="BlockedAppsBox" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="160" FontFamily="Consolas" FontSize="12" TextChanged="Setting_Changed"/>
                                </StackPanel>
                            </Border>

                            <Border x:Name="AllowedAppsCard" Grid.Column="1" Background="{StaticResource BgInput}" CornerRadius="16" Padding="16" Margin="12,0,0,0">
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Allowed apps" Foreground="{StaticResource TextPrimary}" FontSize="14" FontWeight="SemiBold"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="Add last" Style="{StaticResource SecondaryButton}" Click="AddCurrentAllowedApp_Click" Margin="0,0,8,0"/>
                                            <Button Content="Clear" Style="{StaticResource SecondaryButton}" Click="ClearAllowedApps_Click"/>
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Text="Used when you want a tight allow list. Anything not listed here stays quiet." Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,10" TextWrapping="Wrap"/>
                                    <TextBox x:Name="AllowedAppsBox" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="160" FontFamily="Consolas" FontSize="12" TextChanged="Setting_Changed"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <StackPanel x:Name="AppearanceSection" Visibility="Collapsed">
                        <TextBlock Text="Appearance" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="Pick the panel theme and see how it changes the preview." Style="{StaticResource SectionIntroStyle}"/>

                        <Border Style="{StaticResource CardStyle}" Margin="0,20,0,18">
                            <StackPanel>
                                <TextBlock Text="Panel theme" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="These themes change the suggestion panel accent and glow without affecting your settings." Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,6,0,0"/>

                                <UniformGrid Columns="5" Margin="0,18,0,0">
                                    <Button Tag="midnight" Click="Swatch_Click" Style="{StaticResource ThemeCardButtonStyle}" Margin="0,0,16,0">
                                        <Border Style="{StaticResource SoftCardStyle}" Padding="14">
                                            <StackPanel>
                                                <Grid Width="60" Height="60" HorizontalAlignment="Center">
                                                    <Ellipse x:Name="SwatchRingMidnight" Stroke="Transparent" StrokeThickness="3"/>
                                                    <Ellipse Fill="#5050E8" Width="42" Height="42"/>
                                                </Grid>
                                                <TextBlock Text="Midnight" Foreground="{StaticResource TextSecondary}" FontSize="11" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </Button>
                                    <Button Tag="ember" Click="Swatch_Click" Style="{StaticResource ThemeCardButtonStyle}" Margin="0,0,16,0">
                                        <Border Style="{StaticResource SoftCardStyle}" Padding="14">
                                            <StackPanel>
                                                <Grid Width="60" Height="60" HorizontalAlignment="Center">
                                                    <Ellipse x:Name="SwatchRingEmber" Stroke="Transparent" StrokeThickness="3"/>
                                                    <Ellipse Fill="#D06010" Width="42" Height="42"/>
                                                </Grid>
                                                <TextBlock Text="Ember" Foreground="{StaticResource TextSecondary}" FontSize="11" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </Button>
                                    <Button Tag="forest" Click="Swatch_Click" Style="{StaticResource ThemeCardButtonStyle}" Margin="0,0,16,0">
                                        <Border Style="{StaticResource SoftCardStyle}" Padding="14">
                                            <StackPanel>
                                                <Grid Width="60" Height="60" HorizontalAlignment="Center">
                                                    <Ellipse x:Name="SwatchRingForest" Stroke="Transparent" StrokeThickness="3"/>
                                                    <Ellipse Fill="#209A50" Width="42" Height="42"/>
                                                </Grid>
                                                <TextBlock Text="Forest" Foreground="{StaticResource TextSecondary}" FontSize="11" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </Button>
                                    <Button Tag="rose" Click="Swatch_Click" Style="{StaticResource ThemeCardButtonStyle}" Margin="0,0,16,0">
                                        <Border Style="{StaticResource SoftCardStyle}" Padding="14">
                                            <StackPanel>
                                                <Grid Width="60" Height="60" HorizontalAlignment="Center">
                                                    <Ellipse x:Name="SwatchRingRose" Stroke="Transparent" StrokeThickness="3"/>
                                                    <Ellipse Fill="#C83898" Width="42" Height="42"/>
                                                </Grid>
                                                <TextBlock Text="Rose" Foreground="{StaticResource TextSecondary}" FontSize="11" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </Button>
                                    <Button Tag="slate" Click="Swatch_Click" Style="{StaticResource ThemeCardButtonStyle}">
                                        <Border Style="{StaticResource SoftCardStyle}" Padding="14">
                                            <StackPanel>
                                                <Grid Width="60" Height="60" HorizontalAlignment="Center">
                                                    <Ellipse x:Name="SwatchRingSlate" Stroke="Transparent" StrokeThickness="3"/>
                                                    <Ellipse Fill="#586878" Width="42" Height="42"/>
                                                </Grid>
                                                <TextBlock Text="Slate" Foreground="{StaticResource TextSecondary}" FontSize="11" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </Button>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SoftCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Preview notes" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="The preview card at the top updates live so you can see how the active theme, suggestion length, and pace feel together."
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="12"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel x:Name="AdvancedSection" Visibility="Collapsed">
                        <TextBlock Text="Advanced" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="Provider setup, model choices, and prompt controls for advanced tuning." Style="{StaticResource SectionIntroStyle}"/>

                        <Border Style="{StaticResource CardStyle}" Margin="0,20,0,18">
                            <StackPanel>
                                <TextBlock Text="Engine" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Choose the provider that powers Keystroke, then fine-tune its details below." Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,6,0,0"/>
                                <ComboBox x:Name="EngineCombo" Margin="0,16,0,0" SelectionChanged="EngineCombo_Changed">
                                    <ComboBoxItem Content="Gemini (recommended)"/>
                                    <ComboBoxItem Content="GPT-5"/>
                                    <ComboBoxItem Content="Claude"/>
                                    <ComboBoxItem Content="Ollama (local, experimental)"/>
                                    <ComboBoxItem Content="OpenRouter (many models)"/>
                                    <ComboBoxItem Content="Dummy (testing)"/>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock Text="Provider details" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock x:Name="ProviderDetailIntroText" Text="Only the active provider is shown." Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,6,0,0"/>

                                <StackPanel x:Name="GeminiApiKeyPanel" Margin="0,16,0,0">
                                    <TextBlock Text="Gemini API key" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="GeminiApiKeyBox" Margin="0,0,8,0" TextChanged="Setting_Changed"/>
                                        <TextBlock x:Name="GeminiApiKeyStatus" Grid.Column="1" Text="●" FontSize="16" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}"/>
                                    </Grid>
                                </StackPanel>

                                <StackPanel x:Name="Gpt5ApiKeyPanel" Visibility="Collapsed" Margin="0,16,0,0">
                                    <TextBlock Text="OpenAI API key" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="Gpt5ApiKeyBox" Margin="0,0,8,0" TextChanged="Setting_Changed"/>
                                        <TextBlock x:Name="Gpt5ApiKeyStatus" Grid.Column="1" Text="●" FontSize="16" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}"/>
                                    </Grid>
                                </StackPanel>

                                <StackPanel x:Name="ClaudeApiKeyPanel" Visibility="Collapsed" Margin="0,16,0,0">
                                    <TextBlock Text="Claude API key" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="ClaudeApiKeyBox" Margin="0,0,8,0" TextChanged="Setting_Changed"/>
                                        <TextBlock x:Name="ClaudeApiKeyStatus" Grid.Column="1" Text="●" FontSize="16" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}"/>
                                    </Grid>
                                </StackPanel>

                                <StackPanel x:Name="GeminiModelPanel" Margin="0,16,0,0">
                                    <TextBlock Text="Gemini model" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,6"/>
                                    <ComboBox x:Name="GeminiModelCombo" SelectionChanged="Setting_Changed">
                                        <ComboBoxItem Content="gemini-3.1-flash-lite-preview (fastest)" Tag="gemini-3.1-flash-lite-preview"/>
                                        <ComboBoxItem Content="gemini-3-flash-preview (fast)" Tag="gemini-3-flash-preview"/>
                                        <ComboBoxItem Content="gemini-2.5-flash (stable)" Tag="gemini-2.5-flash"/>
                                        <ComboBoxItem Content="gemini-2.5-pro (smart)" Tag="gemini-2.5-pro"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel x:Name="Gpt5ModelPanel" Visibility="Collapsed" Margin="0,16,0,0">
                                    <TextBlock Text="GPT-5 model" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,6"/>
                                    <ComboBox x:Name="Gpt5ModelCombo" SelectionChanged="Setting_Changed">
                                        <ComboBoxItem Content="gpt-5.4-nano (fastest)" Tag="gpt-5.4-nano"/>
                                        <ComboBoxItem Content="gpt-5.4-mini (balanced)" Tag="gpt-5.4-mini"/>
                                        <ComboBoxItem Content="gpt-5.4 (smart)" Tag="gpt-5.4"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel x:Name="ClaudeModelPanel" Visibility="Collapsed" Margin="0,16,0,0">
                                    <TextBlock Text="Claude model" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,6"/>
                                    <ComboBox x:Name="ClaudeModelCombo" SelectionChanged="Setting_Changed">
                                        <ComboBoxItem Content="claude-haiku-4-5 (fast)" Tag="claude-haiku-4-5-20251001"/>
                                        <ComboBoxItem Content="claude-sonnet-4-5 (smart)" Tag="claude-sonnet-4-5-20250214"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel x:Name="OllamaPanel" Visibility="Collapsed" Margin="0,16,0,0">
                                    <Border Style="{StaticResource ExperimentalCardStyle}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="Experimental local engine" Foreground="{StaticResource Warning}" FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="Ollama can be excellent when your local model and hardware are a good fit, but results vary more than hosted providers." Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Text="Ollama model" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,6"/>
                                    <ComboBox x:Name="OllamaModelCombo" SelectionChanged="Setting_Changed">
                                        <ComboBoxItem Content="qwen3:30b-a3b (best)" Tag="qwen3:30b-a3b"/>
                                        <ComboBoxItem Content="qwen3:8b (fast)" Tag="qwen3:8b"/>
                                        <ComboBoxItem Content="mistral:7b (great prose)" Tag="mistral:7b"/>
                                        <ComboBoxItem Content="qwen2.5:7b (well-tested)" Tag="qwen2.5:7b"/>
                                        <ComboBoxItem Content="llama3.1:8b (Meta 8B)" Tag="llama3.1:8b"/>
                                        <ComboBoxItem Content="llama3.2:latest (fastest)" Tag="llama3.2:latest"/>
                                        <ComboBoxItem Content="qwen2.5:0.5b-base (tiny)" Tag="qwen2.5:0.5b-base"/>
                                    </ComboBox>
                                    <TextBlock Text="Endpoint" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,14,0,6"/>
                                    <TextBox x:Name="OllamaEndpointBox" TextChanged="Setting_Changed"/>
                                    <TextBlock x:Name="OllamaStatus" Text="Checking..." Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,10,0,0"/>
                                </StackPanel>

                                <StackPanel x:Name="OpenRouterPanel" Visibility="Collapsed" Margin="0,16,0,0">
                                    <TextBlock Text="OpenRouter API key" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,6"/>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="OpenRouterApiKeyBox" Margin="0,0,8,0" TextChanged="Setting_Changed"/>
                                        <TextBlock x:Name="OpenRouterApiKeyStatus" Grid.Column="1" Text="●" FontSize="16" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="OpenRouter model" Foreground="{StaticResource TextSecondary}" FontSize="12" VerticalAlignment="Center"/>
                                        <Button x:Name="OpenRouterRefreshBtn" Grid.Column="1" Content="Refresh" Style="{StaticResource SecondaryButton}" Click="OpenRouterRefresh_Click"/>
                                    </Grid>
                                    <ComboBox x:Name="OpenRouterModelCombo" SelectionChanged="OpenRouterModelCombo_SelectionChanged"/>
                                    <TextBlock x:Name="OpenRouterModelStatus" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,8,0,0"/>
                                    <TextBlock x:Name="OpenRouterReasoningWarning" Text="Reasoning-first models tend to be slower and less consistent for autocomplete." Foreground="{StaticResource Warning}" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="System prompt" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="SemiBold"/>
                                    <Button Grid.Column="1" Content="Reset to default" Style="{StaticResource SecondaryButton}" Click="ResetPrompt_Click"/>
                                </Grid>
                                <TextBlock Text="These instructions are sent to the model. Only edit them if you want to deeply customize behavior." Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,14" TextWrapping="Wrap"/>
                                <TextBox x:Name="PromptBox" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="320" FontFamily="Consolas" FontSize="12" TextChanged="Setting_Changed"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <Border Grid.Row="2" Background="{StaticResource BgSidebar}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="16" Padding="18,14" Margin="0,18,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Changes save automatically" Foreground="{StaticResource TextMuted}" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock x:Name="SaveStatus" Text=" Saved" Foreground="{StaticResource Success}" FontSize="12" FontWeight="SemiBold" Opacity="0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Done" Style="{StaticResource PrimaryButton}" Click="Done_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
